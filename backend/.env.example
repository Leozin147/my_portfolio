# Porta do servidor Express
PORT=3003

# Origens permitidas no CORS (separadas por vírgula em produção)
ALLOWED_ORIGINS=http://localhost:3000

# Segredo para autenticar o frontend com o backend
API_SECRET=seu-uuid-aqui

# Segredo para assinar os JWT
JWT_SECRET=seu-uuid-aqui

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.dominio.com
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=nome-da-instancia
WHATSAPP_TARGET_NUMBER=5513999999999
